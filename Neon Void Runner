
html_code = '''<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Neon Void Runner</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&display=swap');
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background: #0a0a0f;
            overflow: hidden;
            font-family: 'Orbitron', monospace;
        }
        
        #gameCanvas {
            display: block;
            background: linear-gradient(180deg, #0a0a0f 0%, #1a0a2e 50%, #0a0a0f 100%);
        }
        
        #ui {
            position: absolute;
            top: 20px;
            left: 20px;
            color: #00ffff;
            font-size: 18px;
            text-shadow: 0 0 10px #00ffff, 0 0 20px #00ffff;
            z-index: 10;
        }
        
        #gameOver {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
            color: #ff00ff;
            display: none;
            z-index: 20;
        }
        
        #gameOver h1 {
            font-size: 48px;
            margin-bottom: 20px;
            text-shadow: 0 0 20px #ff00ff, 0 0 40px #ff00ff;
            animation: pulse 1.5s ease-in-out infinite;
        }
        
        #gameOver p {
            font-size: 24px;
            color: #00ffff;
            margin-bottom: 30px;
        }
        
        #restartBtn {
            padding: 15px 40px;
            font-size: 20px;
            font-family: 'Orbitron', monospace;
            background: transparent;
            border: 2px solid #00ffff;
            color: #00ffff;
            cursor: pointer;
            transition: all 0.3s;
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        
        #restartBtn:hover {
            background: #00ffff;
            color: #0a0a0f;
            box-shadow: 0 0 30px #00ffff;
        }
        
        #startScreen {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
            color: #00ffff;
            z-index: 20;
        }
        
        #startScreen h1 {
            font-size: 56px;
            margin-bottom: 10px;
            text-shadow: 0 0 20px #00ffff, 0 0 40px #00ffff;
            animation: glitch 2s infinite;
        }
        
        #startScreen p {
            font-size: 18px;
            color: #ff00ff;
            margin-bottom: 40px;
            opacity: 0.8;
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.6; }
        }
        
        @keyframes glitch {
            0%, 100% { transform: translate(0); }
            20% { transform: translate(-2px, 2px); }
            40% { transform: translate(-2px, -2px); }
            60% { transform: translate(2px, 2px); }
            80% { transform: translate(2px, -2px); }
        }
    </style>
</head>
<body>
    <canvas id="gameCanvas"></canvas>
    
    <div id="ui">
        <div>SCORE: <span id="score">0</span></div>
        <div>SPEED: <span id="speed">1x</span></div>
    </div>
    
    <div id="startScreen">
        <h1>NEON VOID RUNNER</h1>
        <p>CLICK OR SPACE TO JUMP • AVOID OBSTACLES</p>
        <button id="startBtn" style="padding: 15px 40px; font-size: 20px; font-family: 'Orbitron', monospace; background: transparent; border: 2px solid #ff00ff; color: #ff00ff; cursor: pointer; transition: all 0.3s; text-transform: uppercase; letter-spacing: 2px;">INITIATE</button>
    </div>
    
    <div id="gameOver">
        <h1>SIGNAL LOST</h1>
        <p>FINAL SCORE: <span id="finalScore">0</span></p>
        <button id="restartBtn">REBOOT SYSTEM</button>
    </div>

    <script>
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        
        // Game state
        let gameRunning = false;
        let score = 0;
        let gameSpeed = 5;
        let speedMultiplier = 1;
        
        // Player
        const player = {
            x: 100,
            y: canvas.height - 150,
            width: 40,
            height: 40,
            velocityY: 0,
            jumping: false,
            grounded: true,
            color: '#00ffff',
            trail: []
        };
        
        // Obstacles
        let obstacles = [];
        let particles = [];
        let stars = [];
        
        // Initialize stars
        for (let i = 0; i < 100; i++) {
            stars.push({
                x: Math.random() * canvas.width,
                y: Math.random() * canvas.height,
                size: Math.random() * 2,
                speed: Math.random() * 0.5 + 0.1
            });
        }
        
        // Input handling
        function jump() {
            if (player.grounded && gameRunning) {
                player.velocityY = -15;
                player.jumping = true;
                player.grounded = false;
                createParticles(player.x + player.width/2, player.y + player.height, '#00ffff', 10);
            }
        }
        
        document.addEventListener('keydown', (e) => {
            if (e.code === 'Space') {
                e.preventDefault();
                if (!gameRunning && document.getElementById('startScreen').style.display !== 'none') {
                    startGame();
                } else if (!gameRunning && document.getElementById('gameOver').style.display !== 'none') {
                    resetGame();
                } else {
                    jump();
                }
            }
        });
        
        document.addEventListener('mousedown', () => {
            if (gameRunning) jump();
        });
        
        document.addEventListener('touchstart', (e) => {
            e.preventDefault();
            if (gameRunning) jump();
        });
        
        document.getElementById('startBtn').addEventListener('click', startGame);
        document.getElementById('restartBtn').addEventListener('click', resetGame);
        
        function startGame() {
            document.getElementById('startScreen').style.display = 'none';
            gameRunning = true;
            gameLoop();
        }
        
        function resetGame() {
            player.y = canvas.height - 150;
            player.velocityY = 0;
            player.grounded = true;
            obstacles = [];
            particles = [];
            score = 0;
            gameSpeed = 5;
            speedMultiplier = 1;
            document.getElementById('score').textContent = '0';
            document.getElementById('speed').textContent = '1x';
            document.getElementById('gameOver').style.display = 'none';
            gameRunning = true;
            gameLoop();
        }
        
        function createParticles(x, y, color, count) {
            for (let i = 0; i < count; i++) {
                particles.push({
                    x: x,
                    y: y,
                    velocityX: (Math.random() - 0.5) * 10,
                    velocityY: (Math.random() - 0.5) * 10,
                    life: 1,
                    color: color,
                    size: Math.random() * 4 + 2
                });
            }
        }
        
        function spawnObstacle() {
            const types = ['spike', 'block', 'floating'];
            const type = types[Math.floor(Math.random() * types.length)];
            
            let obstacle = {
                x: canvas.width,
                type: type,
                passed: false
            };
            
            if (type === 'spike') {
                obstacle.y = canvas.height - 130;
                obstacle.width = 30;
                obstacle.height = 50;
                obstacle.color = '#ff0055';
            } else if (type === 'block') {
                obstacle.y = canvas.height - 140;
                obstacle.width = 50;
                obstacle.height = 60;
                obstacle.color = '#ff00ff';
            } else {
                obstacle.y = canvas.height - 220;
                obstacle.width = 40;
                obstacle.height = 40;
                obstacle.color = '#ffff00';
            }
            
            obstacles.push(obstacle);
        }
        
        function update() {
            // Player physics
            player.velocityY += 0.8;
            player.y += player.velocityY;
            
            // Ground collision
            if (player.y > canvas.height - 150) {
                player.y = canvas.height - 150;
                player.velocityY = 0;
                player.grounded = true;
                player.jumping = false;
            }
            
            // Player trail
            player.trail.push({ x: player.x, y: player.y, alpha: 1 });
            if (player.trail.length > 10) player.trail.shift();
            player.trail.forEach(t => t.alpha -= 0.1);
            
            // Update stars
            stars.forEach(star => {
                star.x -= star.speed * gameSpeed * 0.1;
                if (star.x < 0) star.x = canvas.width;
            });
            
            // Spawn obstacles
            if (Math.random() < 0.02 + (score * 0.0001)) {
                spawnObstacle();
            }
            
            // Update obstacles
            obstacles.forEach((obs, index) => {
                obs.x -= gameSpeed;
                
                // Collision detection
                if (!obs.passed &&
                    player.x < obs.x + obs.width &&
                    player.x + player.width > obs.x &&
                    player.y < obs.y + obs.height &&
                    player.y + player.height > obs.y) {
                    gameOver();
                }
                
                // Score counting
                if (!obs.passed && obs.x + obs.width < player.x) {
                    obs.passed = true;
                    score += 10;
                    document.getElementById('score').textContent = score;
                    
                    // Increase speed every 100 points
                    if (score % 100 === 0) {
                        speedMultiplier += 0.2;
                        gameSpeed = 5 * speedMultiplier;
                        document.getElementById('speed').textContent = speedMultiplier.toFixed(1) + 'x';
                    }
                }
                
                // Remove off-screen obstacles
                if (obs.x + obs.width < 0) {
                    obstacles.splice(index, 1);
                }
            });
            
            // Update particles
            particles.forEach((p, index) => {
                p.x += p.velocityX;
                p.y += p.velocityY;
                p.velocityY += 0.3;
                p.life -= 0.02;
                if (p.life <= 0) particles.splice(index, 1);
            });
        }
        
        function draw() {
            // Clear canvas with fade effect
            ctx.fillStyle = 'rgba(10, 10, 15, 0.3)';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            
            // Draw stars
            stars.forEach(star => {
                ctx.fillStyle = `rgba(255, 255, 255, ${Math.random() * 0.5 + 0.3})`;
                ctx.beginPath();
                ctx.arc(star.x, star.y, star.size, 0, Math.PI * 2);
                ctx.fill();
            });
            
            // Draw grid floor
            ctx.strokeStyle = 'rgba(0, 255, 255, 0.2)';
            ctx.lineWidth = 1;
            const gridOffset = (Date.now() * gameSpeed * 0.1) % 50;
            for (let i = 0; i < canvas.width + 50; i += 50) {
                ctx.beginPath();
                ctx.moveTo(i - gridOffset, canvas.height - 100);
                ctx.lineTo(i - gridOffset - 100, canvas.height);
                ctx.stroke();
            }
            
            // Draw player trail
            player.trail.forEach(t => {
                ctx.fillStyle = `rgba(0, 255, 255, ${t.alpha * 0.5})`;
                ctx.fillRect(t.x, t.y, player.width, player.height);
            });
            
            // Draw player (neon cube)
            ctx.shadowBlur = 20;
            ctx.shadowColor = player.color;
            ctx.fillStyle = player.color;
            ctx.fillRect(player.x, player.y, player.width, player.height);
            
            // Player inner glow
            ctx.fillStyle = '#ffffff';
            ctx.fillRect(player.x + 5, player.y + 5, player.width - 10, player.height - 10);
            ctx.shadowBlur = 0;
            
            // Draw obstacles
            obstacles.forEach(obs => {
                ctx.shadowBlur = 15;
                ctx.shadowColor = obs.color;
                ctx.fillStyle = obs.color;
                
                if (obs.type === 'spike') {
                    ctx.beginPath();
                    ctx.moveTo(obs.x, obs.y + obs.height);
                    ctx.lineTo(obs.x + obs.width/2, obs.y);
                    ctx.lineTo(obs.x + obs.width, obs.y + obs.height);
                    ctx.closePath();
                    ctx.fill();
                } else {
                    ctx.fillRect(obs.x, obs.y, obs.width, obs.height);
                    // Inner detail
                    ctx.fillStyle = 'rgba(255, 255, 255, 0.3)';
                    ctx.fillRect(obs.x + 5, obs.y + 5, obs.width - 10, obs.height - 10);
                }
                ctx.shadowBlur = 0;
            });
            
            // Draw particles
            particles.forEach(p => {
                ctx.globalAlpha = p.life;
                ctx.fillStyle = p.color;
                ctx.beginPath();
                ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
                ctx.fill();
            });
            ctx.globalAlpha = 1;
        }
        
        function gameOver() {
            gameRunning = false;
            document.getElementById('finalScore').textContent = score;
            document.getElementById('gameOver').style.display = 'block';
            createParticles(player.x + player.width/2, player.y + player.height/2, '#ff00ff', 30);
        }
        
        function gameLoop() {
            if (!gameRunning) return;
            update();
            draw();
            requestAnimationFrame(gameLoop);
        }
        
        // Handle resize
        window.addEventListener('resize', () => {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            player.y = canvas.height - 150;
        });
        
        // Initial draw
        draw();
    </script>
</body>
</html>'''

